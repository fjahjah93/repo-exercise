<odoo>
    <!-- Search View for User Activity Logs -->
    <record id="view_user_activity_search" model="ir.ui.view">
        <field name="name">user.activity.log.search</field>
        <field name="model">user.activity</field>
        <field name="arch" type="xml">
            <search>
                <!-- Searchable Fields -->
                <field name="activity_type" string="Activity Type"/>
                <field name="user_id" string="Responsible User"/>
                <field name="record_name" string="Reference No/Action"/>
                <filter name="group_by_date" string="Today" 
                        domain="[('action_time', '>=', context_today())]"/>

                <!-- Group By Options -->
                <group expand="0" string="Group By">
                    <filter name="group_by_action_time" string="Date" context="{'group_by':'action_time'}"/>
                    <filter name="group_by_user" string="User" context="{'group_by':'user_id'}"/>
                    <filter name="group_by_activity_type" string="Activity Type" context="{'group_by':'activity_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List View for User Activity Logs -->
    <record id="view_user_activity_tree" model="ir.ui.view">
        <field name="name">user.activity.tree</field>
        <field name="model">user.activity</field>
        <field name="arch" type="xml">
            <list create="false" decoration-info="1">
                <field name="user_id" string="Responsible User"/>
                <field name="action_time" string="Date/Time"/>
                <field name="activity_type" string="Activity Types"/>
                <!-- <field name="model_name" string="Model"/> -->
                <field name="task_details" string="Activity Details"/>
                <field name="record_name" string="Reference No/Action"/>
                <!-- <button name="open_details" type="object" string="Details" class="oe_highlight"/> -->
                <button name="open_record" type="object" string="View Record" class="oe_highlight"/>
            </list>
        </field>
    </record>

    <!-- Form View for Detailed User Activity Logs -->
    <record id="view_user_activity_form" model="ir.ui.view">
        <field name="name">user.activity.form</field>
        <field name="model">user.activity</field>
        <field name="arch" type="xml">
            <form create="false">
                <sheet>
                    <group>
                        <field name="action_time" string="Date/Time"/>
                        <field name="activity_type" string="Activity Type"/>
                        <field name="record_name" string="Reference No/Action"/>
                        <field name="user_id" string="Responsible User"/>
                        <field name="model_name" string="Model"/>
                        <field name="task_details" string="Activity Details"/>
                        <button name="open_record" type="object" string="View Record" class="oe_highlight"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to Open User Activity Logs -->
    <record id="action_user_activity_log" model="ir.actions.act_window">
        <field name="name">User Activity Logs</field>
        <field name="res_model">user.activity</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_user_activity_search"/>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_user_activity_log_root" name="User Activity Logs" sequence="10" web_icon="user_activity_log,static/description/icon.png"/>
    <menuitem id="menu_user_activity_log" name="Logs" parent="menu_user_activity_log_root" action="action_user_activity_log"/>
</odoo>
