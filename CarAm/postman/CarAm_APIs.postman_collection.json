    }
  ],
  "variable": [
    { "key": "odoo_base_url", "value": "http://localhost:8069", "type": "string" },
    { "key": "api_token", "value": "PUT_YOUR_ODOO_API_KEY_HERE", "type": "string" }
  ]
}


